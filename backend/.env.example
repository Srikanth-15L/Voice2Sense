# https://console.groq.com/keys
GROQ_API_KEY=

# Optional: default llama-3.1-8b-instant
# GROQ_MODEL=llama-3.1-8b-instant

PORT=3000
NODE_ENV=development

# CORS: comma-separated allowed origins (no spaces, or trim-safe). Omit = allow any origin (dev-friendly).
# CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173
# Set true only if the browser sends credentials (cookies) with fetch:
# CORS_CREDENTIALS=false

# POST /analyze requests per IP per minute (default 120)
# RATE_LIMIT_PER_MINUTE=120

# Optional: Firebase Admin (server-side Firestore). Default: config/firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_PATH=

# --- Twilio PSTN relay (/call/dial) — required for phone calls from the app ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# Public HTTPS base URL Twilio can reach (ngrok/Cloudflare Tunnel). NOT localhost.
# TUNNEL_URL=https://xxxx.ngrok-free.app
# If the phone says "application error", open this URL in a browser — you must see XML, not an ngrok HTML page.
# Twilio Debugger: https://console.twilio.com/us1/monitor/logs/debugger
# Optional: TwiML without media stream (debug only)
# VOICE_RELAY_MEDIA_STREAM=false
# Backend port (Vite proxies /api → this port)
# PORT=3001
